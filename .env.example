# DATABASE_URL is required. PostgreSQL is the only supported database.
# Local (Docker):
DATABASE_URL=postgresql://pokecollection:pokecollection@localhost:5433/pokecollection_dev

# Render (production):
# DATABASE_URL=postgresql://user:password@host/database

# JWT_SECRET — Secret key for signing JSON Web Tokens.
# Generate a secure one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, a random key is generated in-memory (tokens invalidate on restart).
# JWT_SECRET=your-secret-here

# ADMIN_USERNAME — Comma-separated list of usernames that get admin on registration.
# Example: ADMIN_USERNAME=admin,dev.publishcomunicacao@gmail.com
# ADMIN_USERNAME=
